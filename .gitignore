############################################
# Python / general
############################################
__pycache__/
*.py[codz]
*.so
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
ENV/
env/
.env
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.coverage*
htmlcov/
ruff_cache/
.ruff_cache/
.DS_Store

############################################
# IDEs
############################################
.vscode/
.idea/
*.swp
*.swo

############################################
# Large / binary artifacts
############################################
*.mp4
*.mov
*.avi
*.mkv
*.png
*.jpg
*.jpeg
*.npz
*.npy
*.pkl
*.ply
*.elc
*.elp
*.onnx

############################################
# Data folders (keep repo light)
############################################
data/**

# Allow small tracked examples/docs under data if you want:
!data/.gitkeep
!data/README*
!data/**/.gitkeep

############################################
# Pipeline outputs / generated results
############################################
results/**
outputs/**

# If you want to keep a small example output schema file, whitelist it here:
!results/electrode_order.json
!results/**/.gitkeep

############################################
# YOLO / training & inference runs
############################################
runs/**
wandb/**
mlruns/**

############################################
# Models / checkpoints (usually not versioned)
############################################
checkpoints/**
models/**
*.pt
*.pth

############################################
# Temp / intermediate frames
############################################
temp_frames/**
**/temp_frames/**
**/frames/**
**/cropped/**
**/intermediate/**